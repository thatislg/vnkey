<?xml version="1.0" encoding="utf-8"?>
<component>
    <name>org.freedesktop.IBus.VnKey</name>
    <description>VnKey Vietnamese Input Method</description>
    <exec>@IBUS_LIBEXECDIR@/ibus-engine-vnkey --ibus</exec>
    <version>@PROJECT_VERSION@</version>
    <author>VnKey Project</author>
    <license>GPL-3.0-or-later</license>
    <homepage>https://vnkey.app</homepage>
    <textdomain>vnkey-ibus</textdomain>
    <engines>
        <engine>
            <name>vnkey</name>
            <language>vi</language>
            <license>GPL-3.0-or-later</license>
            <author>VnKey Project</author>
            <icon>ibus-vnkey</icon>
            <layout>us</layout>
            <longname>VnKey Vietnamese</longname>
            <description>Vietnamese input method (Telex, VNI, VIQR) with charset support</description>
            <rank>99</rank>
            <symbol>Vi</symbol>
        </engine>
    </engines>
</component>
